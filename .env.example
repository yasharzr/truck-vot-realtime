# Google Maps Directions API key (required for real-time traffic data)
# Get one at https://console.cloud.google.com/apis/credentials
# Enable "Directions API" in your project
GOOGLE_MAPS_API_KEY=your_api_key_here

# Optional: override default route endpoints
# ORIGIN_LAT=43.5100
# ORIGIN_LNG=-79.8900
# DEST_LAT=43.8700
# DEST_LNG=-78.9400
